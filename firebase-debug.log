eate: if isAdmin(); allow update, delete: if isAdmin();\r\n    }\r\n\r\n    match /events/{eventId} {\r\n      allow read: if isAuthenticated() || isAdmin();\r\n      allow create: if true; \r\n      allow update: if isAdmin(); \r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    match /anti_waste/{itemId} {\r\n      allow read: if isAuthenticated() || isAdmin();\r\n      allow create: if isAuthenticated() && request.resource.data.merchantId == request.auth.uid;\r\n      allow update: if isAdmin(); \r\n      allow delete: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);\r\n    }\r\n\r\n    match /products/{productId} {\r\n      allow read: if true;\r\n      allow create: if isAuthenticated() && request.resource.data.merchantId == request.auth.uid;\r\n      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);\r\n    }\r\n  }\r\n}","name":"firestore.rules"}]},"createTime":"2026-04-29T20:00:45.783135Z","metadata":{"services":["cloud.firestore"]}}
