rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // FUNÇÃO AUXILIAR: Verifica se o utilizador tem a role de Admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // FUNÇÃO AUXILIAR: Verifica se o utilizador está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. UTILIZADORES (Users)
    // O Admin pode ler e escrever tudo. O utilizador comum só os seus próprios dados.
    // Lojistas podem ler dados de clientes por NIF (necessário para processar vendas).
    match /users/{userId} {
      allow read: if isAuthenticated(); // Necessário para cruzamento de dados e pesquisas no frontend
      allow create: if true; // Permite a criação de conta no registo
      allow update, delete: if isAdmin() || request.auth.uid == userId;
    }

    // 2. TRANSAÇÕES (Transactions)
    // O Cliente só vê as suas. O Lojista só vê as da sua loja. O Admin vê todas.
    match /transactions/{transactionId} {
      allow read: if isAdmin() || 
                  (isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.merchantId == request.auth.uid));
      allow create: if isAuthenticated(); // Frontend cria com status: 'pending' e a Function resolve
      allow update: if isAdmin() || 
                    (isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.merchantId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // 3. AVALIAÇÕES (Feedbacks)
    match /feedbacks/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // 4. COLEÇÕES DE ACESSO PÚBLICO E DE LEITURA GERAL
    // (Banners, Vantagens, Folhetos e Sistema podem ser lidos por clientes não autenticados ou em onboarding)
    
    match /vantagens/{vantagemId} {
      allow read: if true; // CORRIGIDO: Permite leitura pública na Landing Page / Vantagens
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /leaflets/{leafletId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /leaflet_campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/{document=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 5. PEDIDOS DOS LOJISTAS E NOTIFICAÇÕES (Marketing, Adesões, Mensagens)
    
    match /merchant_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; // O lojista cria na página de login antes de ter conta
      allow update, delete: if isAdmin();
    }

    match /marketing_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.merchantId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /merchant_messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

  }
}