rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES DE SEGURANÇA ---
    
    // Verifica se o utilizador está logado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se é o Administrador Principal (Ponto 2, 3 e 5)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "rochap.filipe@gmail.com";
    }

    // Verifica se o utilizador é o dono do próprio documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- REGRAS POR COLEÇÃO ---

    // 1. UTILIZADORES (Perfis de Clientes e Comerciantes)
    match /users/{userId} {
      // Todos os logados podem ler perfis (necessário para procurar lojistas e nomes)
      allow read: if isAuthenticated();
      // O utilizador pode editar o seu perfil (Ponto 1 e 2) 
      // OU o Admin pode criar/editar/apagar qualquer um (Ponto 2 e aprovação de lojistas)
      allow write: if isAdmin() || isOwner(userId);
    }

    // 2. PEDIDOS DE ADESÃO DE LOJISTAS (Ponto 2 do Login)
    match /merchant_requests/{requestId} {
      // Qualquer pessoa pode enviar um pedido de adesão
      allow create: if true;
      // Apenas o Admin pode ler os pedidos ou apagá-los após aprovar
      allow read, write: if isAdmin();
    }

    // 3. TRANSAÇÕES (Cashback e Resgates)
    match /transactions/{txId} {
      // Clientes e Lojistas precisam de ler o histórico
      allow read: if isAuthenticated();
      // Lojistas podem criar transações no terminal
      allow create: if isAuthenticated();
      // Apenas o Admin pode atualizar ou anular transações (Auditoria)
      allow update, delete: if isAdmin();
    }

    // 4. MENSAGENS PARA COMERCIANTES (Ponto 5)
    match /merchant_messages/{msgId} {
      // Lojistas podem ler e apagar as suas próprias mensagens após lerem
      allow read, delete: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.merchantId);
      // Apenas o Admin pode escrever e enviar estas mensagens
      allow create: if isAdmin();
      allow update: if isAdmin();
    }

    // 5. CAMPANHAS DE MARKETING E NOTIFICAÇÕES (Ponto 6)
    match /marketing_requests/{reqId} {
      // Lojistas podem criar pedidos de marketing
      allow create: if isAuthenticated();
      // Lojistas podem ler os seus próprios pedidos, Admin lê tudo
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.merchantId);
      // Apenas Admin aprova ou remove
      allow update, delete: if isAdmin();
    }

    // 6. BANNERS, FOLHETOS E NOTIFICAÇÕES GERAIS
    match /banners/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /notifications/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /leaflets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /leaflet_campaigns/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 7. FEEDBACK E AVALIAÇÕES
    match /feedbacks/{id} {
      // Clientes criam feedback, todos logados leem
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 8. CONFIGURAÇÕES DE SISTEMA (Preços de Notificação, E-mails de Suporte)
    match /system/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // REGRA DE SEGURANÇA FINAL: Bloqueia tudo o que não foi definido acima
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}