rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isAuthenticated() { return request.auth != null; }
    function isMunicipality() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'municipality';
    }
    function isPartner() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner';
    }
    function isActiveMerchant() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'merchant' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin() ||
        // Qualquer utilizador autenticado pode ver lojas parceiras ativas (listagem pública de lojas)
        (resource.data.role == 'merchant' && resource.data.status == 'active') ||
        // Comerciante ativo pode pesquisar clientes pelo NIF ou nº de cartão
        (isActiveMerchant() && resource.data.role == 'client')
      );
      allow create: if true; 
      allow update, delete: if isAdmin() || request.auth.uid == userId;
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.merchantId == request.auth.uid));
      allow create: if isAuthenticated(); 
      allow update: if isAdmin() || (isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.merchantId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    match /vantagens/{vantagemId} { 
      allow read: if true; 
      allow create: if isAdmin();
      allow update: if isAdmin() || (isPartner() && resource.data.partnerUid == request.auth.uid);
      allow delete: if isAdmin();
    }
    match /banners/{bannerId} { allow read: if true; allow write: if isAdmin(); }
    match /leaflets/{leafletId} { allow read: if true; allow write: if isAdmin(); }
    match /leaflet_campaigns/{campaignId} { allow read: if true; allow write: if isAdmin(); }
    match /system/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /pricing_rules/{ruleId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /municipalities_faqs/{faqId} { 
      allow read: if true; 
      allow create: if isAdmin() || isMunicipality();
      allow update, delete: if isAdmin() || (isMunicipality() && resource.data.distrito == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.distrito);
    }

    match /merchant_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    match /marketing_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if (isAuthenticated() && request.resource.data.merchantId == request.auth.uid) || request.resource.data.isExternal == true;
      allow update, delete: if isAdmin();
    }

    match /merchant_messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.targetId == request.auth.uid) || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || (isAuthenticated() && (resource.data.targetId == request.auth.uid || resource.data.merchantId == request.auth.uid));
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated(); allow create: if isAdmin(); allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated() || isAdmin();
      allow create: if true; 
      allow update: if isAdmin(); 
      allow delete: if isAdmin();
    }

    match /anti_waste/{itemId} {
      allow read: if isAuthenticated() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.merchantId == request.auth.uid;
      allow update: if isAdmin(); 
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.merchantId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
    }
  }
}