rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() { return request.auth != null; }
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email != null
        && request.auth.token.email.lower() == 'rochap.filipe@gmail.com';
    }
    function isAdmin() {
      return isSuperAdmin() ||
        (isSignedIn() 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // USERS: Permite a leitura a utilizadores autenticados (para os lojistas verem clientes e vice-versa)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // TRANSAÇÕES
    match /transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.clientId || isAdmin());
    }

    // FEEDBACKS
    match /feedbacks/{feedbackId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // CONFIGURAÇÕES DO SISTEMA
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PEDIDOS DE LOJISTAS (Registo)
    match /merchant_requests/{docId} {
      allow create: if true; // Qualquer pessoa pode pedir para ser lojista
      allow read, update, delete: if isAdmin();
    }

    // PEDIDOS DE MARKETING (Banners / Folhetos do Lojista)
    match /marketing_requests/{docId} {
      allow create, read: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // CAMPANHAS DE FOLHETOS E BANNERS
    match /leaflet_campaigns/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /banners/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /leaflets/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // VANTAGENS VIP (Página Pública e App)
    match /vantagens/{docId} {
      allow read: if true; // Tem de ser público para a Landing Page
      allow write: if isAdmin();
    }

    // NOTIFICAÇÕES (FCM)
    match /notifications/{docId} {
      allow read, write: if isSignedIn();
    }

    // MENSAGENS ADMIN -> LOJISTAS
    match /merchant_messages/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}