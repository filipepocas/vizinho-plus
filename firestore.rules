rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if true; 
      allow create: if true; 
      allow update, delete: if isAdmin() || request.auth.uid == userId;
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || 
                  (isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.merchantId == request.auth.uid));
      allow create: if isAuthenticated(); 
      allow update: if isAdmin() || 
                    (isAuthenticated() && (resource.data.clientId == request.auth.uid || resource.data.merchantId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    match /vantagens/{vantagemId} { allow read: if true; allow write: if isAdmin(); }
    match /banners/{bannerId} { allow read: if true; allow write: if isAdmin(); }
    match /leaflets/{leafletId} { allow read: if true; allow write: if isAdmin(); }
    match /leaflet_campaigns/{campaignId} { allow read: if true; allow write: if isAdmin(); }
    match /system/{document=**} { allow read: if true; allow write: if isAdmin(); }

    // PEDIDOS (Lojistas, Adesão e Marketing)
    match /merchant_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; // PERMITE QUE O VISITANTE DA LANDING PAGE FAÇA O PEDIDO DE ADESÃO
      allow update, delete: if isAdmin();
    }

    match /marketing_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if (isAuthenticated() && request.resource.data.merchantId == request.auth.uid) || request.resource.data.isExternal == true;
      allow update, delete: if isAdmin();
    }

    match /merchant_messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.merchantId == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}